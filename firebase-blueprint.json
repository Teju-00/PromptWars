{
  "entities": {
    "TimelineStep": {
      "title": "Timeline Step",
      "description": "A step in the election lifecycle.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "order": { "type": "number" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "detailedInfo": { "type": "string" },
        "phase": { "type": "string", "enum": ["Eligibility", "Registration", "Campaign", "Voting", "Counting", "Results"] }
      },
      "required": ["id", "order", "title", "description", "phase"]
    },
    "Flashcard": {
      "title": "Flashcard",
      "description": "An educational card for election terminology.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "term": { "type": "string" },
        "definition": { "type": "string" },
        "category": { "type": "string" }
      },
      "required": ["id", "term", "definition"]
    },
    "QuizQuestion": {
      "title": "Quiz Question",
      "description": "A multiple-choice question for voter education.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "question": { "type": "string" },
        "options": { "type": "array", "items": { "type": "string" } },
        "correctAnswerIndex": { "type": "number" },
        "explanation": { "type": "string" }
      },
      "required": ["id", "question", "options", "correctAnswerIndex"]
    },
    "UserProgress": {
      "title": "User Progress",
      "description": "Tracks a user's completion of election readiness modules and limited metadata.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "displayName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "address": { "type": "string" },
        "dob": { "type": "string" },
        "photoURL": { "type": "string" },
        "registrationStatus": { "type": "string", "enum": ["Not Started", "Submitted", "Verified", "Rejected"] },
        "readinessScore": { "type": "number" },
        "completedSteps": { "type": "array", "items": { "type": "string" } },
        "quizScores": { "type": "object" },
        "simulationCompleted": { "type": "boolean" },
        "documentsVerified": { "type": "array", "items": { "type": "string" } },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "updatedAt"]
    },
    "UserRegistration": {
      "title": "Voter Registration Data",
      "description": "Sensitive registration form data.",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "address": { "type": "string" },
        "dob": { "type": "string" },
        "photoBase64": { "type": "string" }
      }
    },
    "UserDocument": {
      "title": "User Document",
      "description": "A single uploaded document image or record.",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "status": { "type": "string" },
        "url": { "type": "string" },
        "timestamp": { "type": "string" }
      }
    },
    "Constituency": {
      "title": "Constituency Information",
      "description": "Mapping from pincode to election constituencies.",
      "type": "object",
      "properties": {
        "pincode": { "type": "string" },
        "lokSabha": { "type": "string" },
        "assembly": { "type": "string" },
        "phase": { "type": "string" }
      },
      "required": ["pincode", "lokSabha", "assembly"]
    },
    "NewsItem": {
      "title": "News Item",
      "description": "A news article or update for the election portal.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "category": { "type": "string" },
        "date": { "type": "string" },
        "excerpt": { "type": "string" },
        "readTime": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "content", "category", "updatedAt"]
    }
  },
  "firestore": {
    "/news/{newsId}": {
      "schema": "NewsItem",
      "description": "Public news collection for the electoral portal."
    },
    "/timeline/{stepId}": {
      "schema": "TimelineStep",
      "description": "Fixed collection of election timeline steps."
    },
    "/flashcards/{cardId}": {
      "schema": "Flashcard",
      "description": "Fixed collection of flashcards."
    },
    "/quiz_questions/{questionId}": {
      "schema": "QuizQuestion",
      "description": "Fixed collection of quiz questions."
    },
    "/user_progress/{userId}": {
      "schema": "UserProgress",
      "description": "Private user progress data."
    },
    "/user_progress/{userId}/registration/form6": {
      "schema": "UserRegistration",
      "description": "User's voter registration form data."
    },
    "/user_progress/{userId}/documents/{docId}": {
      "schema": "UserDocument",
      "description": "User's uploaded identification documents."
    },
    "/constituencies/{pincode}": {
      "schema": "Constituency",
      "description": "Public constituency lookup data."
    }
  }
}
